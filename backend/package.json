{
  "name": "financas-backend",
  "private": true,
  "version": "5.0.0",
  "description": "Backend API — Finanças Família Sena",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && cp -r prisma dist/",
    "start": "node dist/server.js",
    "prisma:generate": "npx prisma generate",
    "prisma:push": "npx prisma db push",
    "prisma:migrate": "npx prisma migrate deploy",
    "prisma:seed": "node prisma/seed-prod.js"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.2"
  }
}
