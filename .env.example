# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=db_user
POSTGRES_PASSWORD=GERAR_SENHA_FORTE_AQUI
POSTGRES_DB=financas_db

# ─── Backend ─────────────────────────────────────────────
JWT_SECRET=GERAR_STRING_ALEATORIA_32_CHARS_OU_MAIS
APP_URL=https://financas.seudominio.com
CORS_ORIGINS=https://financas.seudominio.com

# ─── Usuário Master (Seed Inicial) ──────────────────────
